{
  "name": "helm",
  "version": "0.1.0",
  "description": "Helm — a reasoning agent orchestrator on the Claude Agent SDK",
  "license": "MIT",
  "type": "module",
  "bin": {
    "helm": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --packages=external --outfile=dist/cli.js",
    "dev": "tsx src/cli.ts",
    "serve": "tsx src/server/main.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "roles",
    "DESIGN.md",
    "USAGE.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
